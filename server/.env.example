# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/synesthesia_eval

# Server port
PORT=3001

# JWT signing secret (change this!)
JWT_SECRET=change-this-to-a-random-secret

# HuggingFace integration
HF_TOKEN=
HF_DATASET=NivDvir/synesthesia-eval
USE_HUGGINGFACE=false

# Google OAuth (optional)
GOOGLE_CLIENT_ID=

# Local clips directory (only needed when USE_HUGGINGFACE=false)
CLIPS_DIR=../../data/clips
